# cc-retrospect configuration
# Copy to ~/.cc-retrospect/config.env and modify as needed.
# Keys use __ as nested field delimiter.

# --- Paths ---
# CLAUDE_DIR=~/.claude
# DATA_DIR=~/.cc-retrospect

# --- Pricing ($/MTok) ---
PRICING__OPUS__INPUT_PER_MTOK=15.0
PRICING__OPUS__OUTPUT_PER_MTOK=75.0
PRICING__OPUS__CACHE_CREATE_PER_MTOK=18.75
PRICING__OPUS__CACHE_READ_PER_MTOK=1.50
PRICING__SONNET__INPUT_PER_MTOK=3.0
PRICING__SONNET__OUTPUT_PER_MTOK=15.0
PRICING__HAIKU__INPUT_PER_MTOK=0.80
PRICING__HAIKU__OUTPUT_PER_MTOK=4.0

# --- Thresholds ---
THRESHOLDS__LONG_SESSION_MINUTES=120
THRESHOLDS__LONG_SESSION_MESSAGES=200
THRESHOLDS__MEGA_PROMPT_CHARS=1000
THRESHOLDS__MEGA_PROMPT_VERY_LONG_CHARS=3000
THRESHOLDS__MEGA_PROMPT_NEWLINE_DENSITY=0.02
THRESHOLDS__MAX_SUBAGENTS_PER_SESSION=10
THRESHOLDS__MAX_CLAUDEMD_BYTES=50000
THRESHOLDS__TOOL_CHAIN_THRESHOLD=5
THRESHOLDS__DAILY_COST_WARNING=500
THRESHOLDS__COST_TIP_THRESHOLD=100
THRESHOLDS__FRUSTRATION_TIP_THRESHOLD=3
THRESHOLDS__COMPACT_NUDGE_FIRST=150
THRESHOLDS__COMPACT_NUDGE_SECOND=300
THRESHOLDS__LEARN_REFRESH_INTERVAL=50

# --- Feature Toggles (true/false) ---
HINTS__SESSION_START=true
HINTS__PRE_TOOL=true
HINTS__POST_TOOL=true
HINTS__USER_PROMPT=true
HINTS__DAILY_HEALTH=true
HINTS__DAILY_DIGEST=true
HINTS__WASTE_ON_STOP=true
HINTS__AUTO_LEARN=true

# --- Messages (all user-facing strings — customize wording, tone, language) ---
MESSAGES__PREFIX=[cc-retrospect]

# SessionStart tips
MESSAGES__TIP_LONG_SESSION=Tip: Start fresh more often — your last ran {duration}.
MESSAGES__TIP_MODEL_SONNET=Tip: Consider /model sonnet (last session: {cost}).
MESSAGES__TIP_FRUSTRATION=Tip: When stuck, /clear and restate — iterating grows context and cost.
MESSAGES__TIP_SUBAGENT_OVERUSE=Tip: Use Grep/Read instead of spawning Agent for simple lookups.

# Daily health
MESSAGES__HEALTH_LONG_SESSIONS=Health: {count} long sessions in last 3 days (avg {avg_duration}).
MESSAGES__HEALTH_COST_VELOCITY=Health: Averaging {daily_cost}/day. Projected monthly: {monthly_cost}.
MESSAGES__HEALTH_NO_DATA=Health: No session data found — Stop hook may not be firing.

# Daily digest
MESSAGES__DIGEST_SUMMARY=Yesterday: {count} sessions, {cost}, {frustrations} frustrations, {subagents} subagents, {compactions} compactions.
MESSAGES__DIGEST_MODEL_TIP=Model tip: {cost} spent on Opus for simple tasks — try /model sonnet.

# Budget
MESSAGES__BUDGET_ALERT=Budget alert: {cost} spent today (threshold: {threshold}).

# PreToolUse hints
MESSAGES__HINT_WEBFETCH_GITHUB=Consider using `gh` CLI instead of WebFetch for {domain} — structured output, fewer tokens.
MESSAGES__HINT_AGENT_SIMPLE=This looks like a simple search — try Grep or Glob directly to save a subagent spawn.
MESSAGES__HINT_BASH_CHAIN=Multiple consecutive Bash calls — consider combining with && or writing a script.

# PostToolUse hints
MESSAGES__HINT_COMPACT_FIRST=Session at {count}+ tool calls. Context is growing expensive — consider /compact or starting fresh.
MESSAGES__HINT_COMPACT_SECOND=Session at {count}+ tool calls. Strongly recommend /compact — each message re-reads the full history.
MESSAGES__HINT_SUBAGENT_LIMIT=You've spawned {count} subagents this session. Each loads the full system context. Try Grep/Read for simple lookups.

# UserPromptSubmit hints
MESSAGES__HINT_MEGA_PASTE=Large paste detected ({chars} chars). Consider writing to a temp file and referencing it — saves tokens on every future turn.
MESSAGES__HINT_MEGA_LONG=Very long prompt ({chars} chars). This inflates conversation history. Consider using a file reference.

# Stop hook waste flags
MESSAGES__WASTE_WEBFETCH={count} WebFetch→GitHub (use gh CLI)
MESSAGES__WASTE_TOOL_CHAINS={count} long tool chains
MESSAGES__WASTE_MEGA_PROMPTS={count} mega prompts
MESSAGES__WASTE_DUP_READS={count} duplicate read chains

# Onboarding
MESSAGES__WELCOME_WITH_DATA=Welcome! Found {count} sessions ({cost}). Run /cc-retrospect:analyze for a full report.
MESSAGES__WELCOME_NO_DATA=Welcome! No session data yet. Hooks will start tracking automatically.

# --- Logging ---
# CC_RETROSPECT_LOG_LEVEL=WARNING
